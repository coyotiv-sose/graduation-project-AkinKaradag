{
    "name": "template-node",
    "version": "0.0.0",
    "private": true,
    "description": "Node + PlantUML Starter Template",
    "license": "MIT",
    "scripts": {
        "start": "node ./bin/www",
        "dev": "nodemon ./bin/www",
        "eslint:check": "npx eslint .",
        "eslint:fix": "npx eslint --fix .",
        "test": "NODE_OPTIONS='--no-experimental-webstorage' DOTENV_CONFIG_PATH=./.env.test.local jest",
        "test:watch": "NODE_OPTIONS='--no-experimental-webstorage' DOTENV_CONFIG_PATH=./.env.test.local jest  --watch --coverage",
        "test:coverage": "NODE_OPTIONS='--no-experimental-webstorage' DOTENV_CONFIG_PATH=./.env.test.local jest --coverage"
    },
    "devDependencies": {
        "eslint": "^8.19.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-prettier": "^4.2.1",
        "jest": "^29.7.0",
        "nodemon": "^3.1.14",
        "prettier": "^2.7.1",
        "supertest": "^7.2.2"
    },
    "dependencies": {
        "axios": "^1.13.4",
        "convert-units": "^2.3.4",
        "cookie-parser": "^1.4.7",
        "debug": "^4.4.3",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "http-errors": "^2.0.1",
        "mongoose": "^9.2.0",
        "mongoose-autopopulate": "^1.2.1",
        "morgan": "^1.10.1",
        "pug": "^3.0.3"
    },
    "jest": {
        "setupFiles": [
            "dotenv/config"
        ]
    }
}
